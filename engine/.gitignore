# Scanner cache (per-workspace; gitignored from the scanned repo's side too)
.dsc_cache/

# Python bytecode
__pycache__/
*.pyc

# Local test artifacts
.pytest_cache/

# pip editable-install metadata (regenerated by `pip install -e .`)
*.egg-info/

# PyInstaller scratch dirs (regenerated per build by dsc-cli.spec)
build/
dist/
